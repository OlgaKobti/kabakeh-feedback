{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "menu.kabakeh.com" }],
      "destination": "/menu",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.kabakeh.com" }],
      "destination": "https://kabakeh.com",
      "permanent": true
    },
    {
      "source": "/home",
      "missing": [{ "type": "host", "value": "kabakeh.com" }],
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "kabakeh.com" }],
      "destination": "/home"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/keepalive",
      "schedule": "0 8 * * *"
    }
  ]
}